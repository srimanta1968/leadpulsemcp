{
  "family": "leadpulse-mcp",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "1024",
  "memory": "2048",
  "runtimePlatform": {
    "cpuArchitecture": "X86_64",
    "operatingSystemFamily": "LINUX"
  },
  "executionRoleArn": "arn:aws:iam::${AWS_ACCOUNT_ID}:role/leadpulse-mcp-exec",
  "taskRoleArn": "arn:aws:iam::${AWS_ACCOUNT_ID}:role/leadpulse-mcp-task",
  "containerDefinitions": [
    {
      "name": "leadpulse-mcp",
      "image": "${DOCKERHUB_USERNAME}/projex-leadpulse-mcp:${IMAGE_TAG}",
      "essential": true,
      "portMappings": [
        { "containerPort": 8000, "protocol": "tcp" }
      ],
      "environment": [
        { "name": "MCP_HOST", "value": "0.0.0.0" },
        { "name": "MCP_PORT", "value": "8000" },
        { "name": "LOG_LEVEL", "value": "info" },
        { "name": "LEADPULSE_URL", "value": "${LEADPULSE_URL}" },
        { "name": "MONGODB_DB", "value": "${MONGODB_DB}" },
        { "name": "SENDER_AGENTS_PER_CONTAINER", "value": "4" },
        { "name": "AWS_REGION", "value": "${AWS_REGION}" }
      ],
      "secrets": [
        {
          "name": "BOOTSTRAP_SECRET",
          "valueFrom": "arn:aws:secretsmanager:${AWS_REGION}:${AWS_ACCOUNT_ID}:secret:leadpulse-mcp/bootstrap-secret"
        },
        {
          "name": "LEADPULSE_TOKEN",
          "valueFrom": "arn:aws:secretsmanager:${AWS_REGION}:${AWS_ACCOUNT_ID}:secret:leadpulse-mcp/leadpulse-token"
        },
        {
          "name": "MCP_BOOTSTRAP_KEY",
          "valueFrom": "arn:aws:secretsmanager:${AWS_REGION}:${AWS_ACCOUNT_ID}:secret:leadpulse-mcp/bootstrap-key"
        },
        {
          "name": "MONGODB_URL",
          "valueFrom": "arn:aws:secretsmanager:${AWS_REGION}:${AWS_ACCOUNT_ID}:secret:leadpulse-mcp/mongodb-url"
        }
      ],
      "healthCheck": {
        "command": ["CMD-SHELL", "curl -fsS http://127.0.0.1:8000/health || exit 1"],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 40
      },
      "stopTimeout": 60,
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/leadpulse-mcp",
          "awslogs-region": "${AWS_REGION}",
          "awslogs-stream-prefix": "mcp",
          "awslogs-create-group": "true"
        }
      },
      "readonlyRootFilesystem": false,
      "linuxParameters": {
        "initProcessEnabled": true
      }
    }
  ]
}
