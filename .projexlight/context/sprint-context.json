  "project": {
    "id": "6f3a50a3-8701-42ae-b1c5-aa6e8a4ad0d8",
    "name": "Leadpulse MCP",
    "description": "The MCP (Managed Campaign Processor) is an **external** Docker-based agent system that executes campaign email delivery on behalf of the ProjexLight CRM. It is deployed and scaled separately in AWS (ECS Fargate or EC2 ASG) and communicates with the CRM via HTTPS. The MCP does not share a database or codebase with the CRM."
  },
