# Frontend Environment Configuration
# Generated for Leadpulse MCP
# Framework: react

# ============================================
# API CONFIGURATION
# ============================================
# Backend API URL
VITE_API_URL=http://localhost:3000/api
VITE_API_VERSION=v1

# ============================================
# APPLICATION
# ============================================
VITE_APP_NAME=Leadpulse MCP
VITE_APP_VERSION=1.0.0
VITE_APP_ENV=development

# ============================================
# REACT SPECIFIC
# ============================================
# React (Vite)
VITE_PUBLIC_URL=/

# ============================================
# AUTHENTICATION
# ============================================
VITE_AUTH_STORAGE_KEY=auth_token
VITE_REFRESH_TOKEN_KEY=refresh_token

# ============================================
# FEATURE FLAGS
# ============================================
VITE_ENABLE_DARK_MODE=true
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_DEBUG=true

# ============================================
# OPTIONAL SERVICES (uncomment if needed)
# ============================================
# Analytics
# VITE_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX

# Error Tracking
# VITE_SENTRY_DSN=https://xxx@sentry.io/xxx

# Payment
# VITE_STRIPE_PUBLIC_KEY=pk_test_xxxxx

# ============================================
# IMPORTANT NOTES
# ============================================
# 1. NEVER commit .env to version control
# 2. Only VITE_ prefixed vars are exposed to client
# 3. Never put secrets in client-side env vars
# 4. Copy this file to .env and configure values
