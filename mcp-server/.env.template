# ============================================
# MCP Server Configuration
# ============================================
MCP_ENCRYPTION_KEY=your_encryption_key_here
WORKSPACE_PATH=/workspace
MCP_SERVER_PORT=8766
MCP_SERVER_HOST=0.0.0.0

# Dev MCP Port (code review, development assistance)
MCP_DEV_PORT=8766

# Test MCP Port (UI testing, API functional tests)
MCP_TEST_PORT=8000

# ============================================
# Database Configuration (PostgreSQL default)
# ============================================
DB_TYPE=postgresql
DB_HOST=postgres
DB_PORT=5432
DB_NAME=appdb
DB_USER=appuser
DB_PASSWORD=apppassword

# ============================================
# ProjexLight API Configuration
# ============================================
# PROJEXLIGHT_API_URL=http://host.docker.internal:9999
# PROJEXLIGHT_API_KEY=your_api_key_here

# ============================================
# LLM Configuration (optional - for AI features)
# ============================================
# LLM_PROVIDER=openai
# LLM_MODEL_REVIEW=gpt-4o-mini
# OPENAI_API_KEY=your_openai_key

# ============================================
# AWS DynamoDB Configuration (if using)
# ============================================
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key
# AWS_REGION=us-east-1
# DYNAMODB_ENDPOINT=http://localhost:8000  # For local DynamoDB

# ============================================
# Cassandra Configuration (if using)
# ============================================
# CASSANDRA_HOSTS=localhost
# CASSANDRA_PORT=9042
# CASSANDRA_KEYSPACE=your_keyspace
# CASSANDRA_USERNAME=cassandra
# CASSANDRA_PASSWORD=cassandra
